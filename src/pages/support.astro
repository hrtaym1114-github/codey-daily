---
import Base from '../layouts/Base.astro';

// 設定（ayumuのGitHub Sponsorsプロフィールが整い次第更新）
const GITHUB_USER = 'hrtaym1114-github';
const GITHUB_REPO = 'codey-daily';
const SPONSOR_URL = `https://github.com/sponsors/${GITHUB_USER}`;
const REPO_URL = `https://github.com/${GITHUB_USER}/${GITHUB_REPO}`;
const X_HANDLE = 'Amu_Lab__';
---
<Base title="Codey Dailyを応援する — Support" description="Codey Dailyは無料の Claude Code 学習アプリです。GitHub Sponsors で開発を応援できます。">
  <main class="container mx-auto px-4 py-6 max-w-2xl">
    <nav class="text-sm mb-3"><a href="/" class="text-blue-600 hover:underline">← トップ</a></nav>

    <header class="mb-6">
      <h1 class="text-3xl font-bold mb-1">❤️ Codey Daily を応援</h1>
      <p class="text-gray-600 text-sm">Claude Code 学習を毎日続けたい人のために、無料で提供しています</p>
    </header>

    <section class="bg-white rounded-xl shadow-md p-6 mb-5">
      <h2 class="text-lg font-bold mb-3">🚀 Codey Daily について</h2>
      <p class="text-sm text-gray-700 mb-3">
        Claude Code の標準機能 73+ を毎日5秒で発見・反復学習できる Web アプリ。
        広告なし・登録不要で、一人で開発しています。
      </p>
      <p class="text-sm text-gray-700">
        運営は完全にボランティアベース。サーバー代は Cloudflare の無料枠で賄っていますが、
        コンテンツの拡充・新機能開発の継続には皆さんのサポートが力になります。
      </p>
    </section>

    <section class="bg-white rounded-xl shadow-md p-6 mb-5">
      <h2 class="text-lg font-bold mb-3">💖 応援する3つの方法</h2>

      <div class="space-y-3">
        <a href={SPONSOR_URL} target="_blank" rel="noopener" class="block bg-pink-500 text-white rounded-xl p-4 hover:bg-pink-600 transition">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-bold text-lg mb-0.5">❤️ GitHub Sponsors</p>
              <p class="text-xs opacity-90">月¥100〜¥1,000で継続的にサポート</p>
            </div>
            <span class="text-2xl">→</span>
          </div>
        </a>

        <a href={REPO_URL} target="_blank" rel="noopener" class="block bg-gray-800 text-white rounded-xl p-4 hover:bg-gray-900 transition">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-bold text-lg mb-0.5">⭐ GitHub Star</p>
              <p class="text-xs opacity-90">0円・1クリックで応援（リポジトリにスター）</p>
            </div>
            <span class="text-2xl">→</span>
          </div>
        </a>

        <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent('Claude Code を毎日5秒で発見できる Codey Daily を使ってます\n')}&url=${encodeURIComponent('https://codey-daily.hrtaym1114.workers.dev/')}`} target="_blank" rel="noopener" class="block bg-sky-500 text-white rounded-xl p-4 hover:bg-sky-600 transition">
          <div class="flex items-center justify-between">
            <div>
              <p class="font-bold text-lg mb-0.5">📤 X.com で紹介</p>
              <p class="text-xs opacity-90">他の Claude Code ユーザーに広めて</p>
            </div>
            <span class="text-2xl">→</span>
          </div>
        </a>
      </div>
    </section>

    <section class="bg-white rounded-xl shadow-md p-6 mb-5">
      <h2 class="text-lg font-bold mb-3">🛣 ロードマップ（応援が集まれば）</h2>
      <ul class="space-y-2 text-sm text-gray-700">
        <li class="flex gap-2"><span>🔄</span> Spaced Repetition (Anki式の最適復習間隔)</li>
        <li class="flex gap-2"><span>📊</span> 学習曲線グラフ・弱点リスト</li>
        <li class="flex gap-2"><span>🌐</span> 英語UI対応（グローバル展開）</li>
        <li class="flex gap-2"><span>📱</span> PWA + Web Push 通知（朝の今日の機能）</li>
        <li class="flex gap-2"><span>🔍</span> 全文検索（Pagefind）</li>
        <li class="flex gap-2"><span>📲</span> iOS Native 版</li>
      </ul>
    </section>

    <section class="bg-gray-50 rounded-xl p-5 mb-5">
      <h2 class="text-base font-bold mb-2">📬 お問い合わせ</h2>
      <p class="text-sm text-gray-600">
        フィードバック・機能リクエストは X.com の
        <a href={`https://x.com/${X_HANDLE}`} target="_blank" rel="noopener" class="text-blue-600 hover:underline">@{X_HANDLE}</a>
        まで。
      </p>
    </section>

    <footer class="text-center text-xs text-gray-400 mt-6">
      <p>by ayumu | Open Source on <a href={REPO_URL} target="_blank" rel="noopener" class="text-blue-600 hover:underline">GitHub</a></p>
    </footer>
  </main>
</Base>
