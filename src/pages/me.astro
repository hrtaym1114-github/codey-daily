---
import Base from '../layouts/Base.astro';
---
<Base title="マイページ — Codey Daily" description="あなたの学習記録">
  <main class="container mx-auto px-4 py-6 max-w-2xl">
    <nav class="text-sm mb-3"><a href="/" class="text-blue-600 hover:underline">← トップ</a></nav>

    <div id="loading" class="text-center text-gray-400 py-12">読み込み中...</div>
    <div id="not-logged-in" class="hidden text-center bg-white rounded-xl shadow-md p-8">
      <p class="text-lg mb-4">ログインすると個人の学習記録を管理できます</p>
      <button id="btn-login" class="bg-blue-500 text-white rounded-lg px-6 py-3 font-semibold hover:bg-blue-600">
        Googleでログイン
      </button>
    </div>

    <div id="content" class="hidden">
      <header class="bg-white rounded-xl shadow-md p-6 mb-5 text-center">
        <img id="user-avatar" src="" alt="" class="w-20 h-20 rounded-full mx-auto mb-3 hidden" />
        <h1 class="text-2xl font-bold mb-1" id="user-name">-</h1>
        <p class="text-sm text-gray-500" id="user-email">-</p>
      </header>

      <section class="grid grid-cols-3 gap-3 mb-5">
        <div class="bg-white rounded-xl shadow-md p-4 text-center">
          <p class="text-3xl font-black text-blue-500" id="stat-touched">0</p>
          <p class="text-xs text-gray-500 mt-1">学習機能数</p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-4 text-center">
          <p class="text-3xl font-black text-orange-500" id="stat-current">0</p>
          <p class="text-xs text-gray-500 mt-1">連続日数 🔥</p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-4 text-center">
          <p class="text-3xl font-black text-emerald-500" id="stat-longest">0</p>
          <p class="text-xs text-gray-500 mt-1">最長記録</p>
        </div>
      </section>

      <section class="bg-white rounded-xl shadow-md p-5 mb-5">
        <h2 class="font-bold mb-3">📊 学習進度</h2>
        <p class="text-sm text-gray-600 mb-2">73 機能のうち <strong id="progress-count">0</strong> 機能を学習済み</p>
        <div class="bg-gray-200 rounded-full h-3 overflow-hidden">
          <div id="progress-bar" class="bg-blue-500 h-3 transition-all" style="width: 0%"></div>
        </div>
        <p class="text-xs text-gray-400 mt-2 text-right" id="progress-percent">0%</p>
      </section>

      <section class="bg-white rounded-xl shadow-md p-5 mb-5">
        <h2 class="font-bold mb-3">💡 アカウントの仕組み</h2>
        <ul class="text-sm text-gray-600 space-y-1.5">
          <li>✅ 進度・ストリークが <strong>クロスデバイス同期</strong></li>
          <li>✅ ブラウザ変えても記録が残る</li>
          <li>✅ 匿名利用時の進度も自動マージ</li>
          <li>🔒 個人情報は email/名前/写真のみ</li>
        </ul>
      </section>

      <section class="bg-rose-50 border border-rose-200 rounded-xl p-5">
        <h2 class="font-bold text-rose-700 mb-2">🗑 アカウント関連</h2>
        <button id="btn-reset" class="text-sm text-rose-600 hover:underline mr-4">学習記録をリセット</button>
        <button id="btn-logout-page" class="text-sm text-rose-600 hover:underline">ログアウト</button>
      </section>
    </div>
  </main>

  <script is:inline>
    function getAnonId() {
      let id = localStorage.getItem('cd_anon_id');
      if (!id) { id = crypto.randomUUID(); localStorage.setItem('cd_anon_id', id); }
      return id;
    }

    async function load() {
      const me = await fetch('/api/me').then(r => r.json());
      document.getElementById('loading').classList.add('hidden');

      if (!me.user) {
        document.getElementById('not-logged-in').classList.remove('hidden');
        document.getElementById('btn-login').addEventListener('click', () => {
          location.href = '/api/auth/google/login?anon_id=' + encodeURIComponent(getAnonId());
        });
        return;
      }

      document.getElementById('content').classList.remove('hidden');

      // user info
      if (me.user.picture) {
        const img = document.getElementById('user-avatar');
        img.src = me.user.picture;
        img.classList.remove('hidden');
      }
      document.getElementById('user-name').textContent = me.user.name || me.user.email;
      document.getElementById('user-email').textContent = me.user.email;

      // stats
      const touched = me.stats.total_touched ?? 0;
      const current = me.stats.current_streak ?? 0;
      const longest = me.stats.longest_streak ?? 0;
      document.getElementById('stat-touched').textContent = touched;
      document.getElementById('stat-current').textContent = current;
      document.getElementById('stat-longest').textContent = longest;

      // progress
      const total = 73;
      const pct = Math.round((touched / total) * 100);
      document.getElementById('progress-count').textContent = touched;
      document.getElementById('progress-bar').style.width = pct + '%';
      document.getElementById('progress-percent').textContent = pct + '%';

      // logout
      document.getElementById('btn-logout-page').addEventListener('click', async () => {
        if (!confirm('ログアウトしますか?')) return;
        await fetch('/api/auth/logout', { method: 'POST' });
        location.href = '/';
      });

      // reset
      document.getElementById('btn-reset').addEventListener('click', async () => {
        if (!confirm('全ての学習記録をリセットします。よろしいですか?')) return;
        await fetch('/api/progress', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'reset', featureId: '' }),
        });
        location.reload();
      });
    }
    load();
  </script>
</Base>
