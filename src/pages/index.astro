---
import Base from '../layouts/Base.astro';
---
<Base title="Codey Daily — Claude Code を毎日5秒で発見">
  <main class="container mx-auto px-4 py-8 max-w-2xl">
    <h1 class="text-4xl font-bold mb-2">Codey Daily</h1>
    <p class="text-gray-600 mb-8">Claude Code を毎日5秒で発見するWebアプリ</p>

    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 rounded mb-6">
      <p class="font-semibold">🚧 Phase 1: 基盤構築中</p>
      <p class="text-sm text-gray-600 mt-2">公開予定: 2026-05-22</p>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-2xl font-bold mb-4">✨ Coming Soon</h2>
      <ul class="space-y-2 text-gray-700">
        <li>📅 毎朝1機能発見</li>
        <li>📊 進度マップ</li>
        <li>🔥 ストリーク</li>
        <li>📲 PWA + Web Push</li>
      </ul>
    </div>
  </main>
</Base>
