---
import Base from '../layouts/Base.astro';
import featuresData from '../../data/features.json';

const data = featuresData as any;
const total = data.features.length;
const categories = [...new Set(data.features.map((f: any) => f.category))].map((c: any) => ({
  id: c,
  count: data.features.filter((f: any) => f.category === c).length,
}));

const labels: Record<string, string> = {
  'slash-command': 'Slash Commands',
  'tool': 'Built-in Tools',
  'hook': 'Hooks',
  'agent': 'Agents',
  'skill': 'Skills',
  'mcp': 'MCP',
  'mode': 'Modes',
  'file': 'Files & Memory',
  'cli': 'CLI Flags',
  'setting': 'Settings',
};
---
<Base
  title="Codey Daily — Claude Code を毎日5秒で発見"
  description={`Claude Code の標準機能 ${total} を毎朝1個ずつ発見・学習`}
>
  <main class="container mx-auto px-4 py-6 max-w-2xl">
    <header class="mb-5">
      <h1 class="text-3xl font-bold mb-1">Codey Daily</h1>
      <p class="text-gray-600 text-sm">Claude Code の標準機能 {total} を3つの方法で学ぶ</p>
    </header>

    <section id="streak-bar" class="bg-white rounded-lg shadow-sm border border-gray-100 p-3 mb-5 text-sm">
      <div class="flex justify-between items-center">
        <span>
          <span class="font-bold text-base" id="streak-count">-</span>
          <span class="text-gray-600"> 日連続 🔥</span>
          <span class="text-gray-400 text-xs ml-1" id="longest-streak-label"></span>
        </span>
        <span>累計 <span class="font-bold" id="touched-count">-</span> / {total} 機能</span>
      </div>
      <p id="streak-cheer" class="text-xs text-amber-600 mt-1 hidden"></p>
    </section>

    <section class="grid grid-cols-4 gap-2 mb-5">
      <a href="/" class="bg-blue-500 text-white rounded-xl p-3 text-center shadow-md hover:shadow-lg transition">
        <p class="text-xl mb-1">📅</p>
        <p class="text-xs font-bold">今日</p>
      </a>
      <a href="/flashcard" class="bg-white border-2 border-gray-200 rounded-xl p-3 text-center shadow-sm hover:border-blue-400 hover:bg-blue-50 transition">
        <p class="text-xl mb-1">🃏</p>
        <p class="text-xs font-bold">フラッシュ</p>
      </a>
      <a href="/quiz" class="bg-white border-2 border-gray-200 rounded-xl p-3 text-center shadow-sm hover:border-blue-400 hover:bg-blue-50 transition">
        <p class="text-xl mb-1">🎯</p>
        <p class="text-xs font-bold">クイズ</p>
      </a>
      <a href="/changelog" class="bg-white border-2 border-gray-200 rounded-xl p-3 text-center shadow-sm hover:border-blue-400 hover:bg-blue-50 transition">
        <p class="text-xl mb-1">📜</p>
        <p class="text-xs font-bold">更新</p>
      </a>
    </section>

    <section class="bg-pink-50 border border-pink-200 rounded-lg p-3 mb-5 text-sm">
      <a href="/support" class="flex justify-between items-center hover:bg-pink-100 -m-1 p-1 rounded transition">
        <span class="text-pink-700">❤️ Codey Daily を応援する</span>
        <span class="text-pink-500 text-xs">GitHub Sponsors / Star →</span>
      </a>
    </section>

    <section id="today-card" class="bg-white rounded-xl shadow-md p-6 mb-5">
      <p class="text-xs text-gray-500 mb-2">✨ 今日の機能</p>
      <div id="today-loading" class="text-gray-400 text-sm">読み込み中...</div>
      <div id="today-content" style="display:none">
        <h2 class="text-2xl font-bold mb-1" id="feature-name"></h2>
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-3" id="feature-category"></p>
        <p class="text-gray-700 mb-4" id="feature-summary"></p>
        <div id="feature-examples" class="mb-4"></div>
        <div id="feature-links" class="mb-3"></div>
        <div class="flex gap-2 mb-3">
          <button id="btn-touch" class="flex-1 bg-blue-500 text-white rounded-lg py-2 font-semibold hover:bg-blue-600 active:scale-95 transition">
            ✅ 触った
          </button>
          <button id="btn-skip" class="flex-1 bg-gray-200 text-gray-700 rounded-lg py-2 font-semibold hover:bg-gray-300 active:scale-95 transition">
            ⏭️ 後で
          </button>
        </div>
        <a id="feature-link" href="#" class="block text-center text-sm text-blue-600 hover:underline">📚 詳細ページを開く →</a>
      </div>
    </section>

    <section class="bg-white rounded-xl shadow-md p-6 mb-5">
      <h2 class="text-lg font-bold mb-3">📂 カテゴリ別</h2>
      <ul class="space-y-1 text-sm">
        {categories.map((c) => (
          <li>
            <a href={`/category/${c.id}`} class="flex justify-between border-b border-gray-100 py-2 hover:bg-gray-50 px-2 -mx-2 rounded transition">
              <span>{labels[c.id] ?? c.id}</span>
              <span class="text-gray-500">{c.count} 件 →</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <footer class="text-center text-xs text-gray-400 mt-8">
      <p>3モード学習: 発見 + フラッシュカード + クイズ</p>
      <p class="mt-1">累計 {total} 機能 / Open Source</p>
      <p class="mt-2">
        <a href="/stats" class="text-blue-600 hover:underline">📊 統計</a> ·
        <a href="/support" class="text-blue-600 hover:underline">❤️ 応援</a> ·
        <a href="/changelog" class="text-blue-600 hover:underline">📜 変更履歴</a>
      </p>
    </footer>
  </main>

  <script>
    function getAnonId(): string {
      let id = localStorage.getItem('cd_anon_id');
      if (!id) {
        id = crypto.randomUUID();
        localStorage.setItem('cd_anon_id', id);
      }
      return id;
    }
    const anonId = getAnonId();

    async function loadToday() {
      const res = await fetch('/api/today');
      if (!res.ok) {
        document.getElementById('today-loading')!.textContent = '読み込みエラー';
        return;
      }
      const data = await res.json();
      const f = data.feature;

      (document.getElementById('feature-name') as HTMLElement).textContent = f.name;
      (document.getElementById('feature-category') as HTMLElement).textContent = f.category;
      (document.getElementById('feature-summary') as HTMLElement).textContent = f.summary_ja;
      (document.getElementById('feature-link') as HTMLAnchorElement).href = `/feature/${f.id}`;

      const exContainer = document.getElementById('feature-examples') as HTMLElement;
      if (f.examples?.length) {
        exContainer.innerHTML = '<p class="text-sm font-semibold mb-2">💡 使用例</p>' +
          f.examples.map((ex: { title: string; code: string }) =>
            `<pre class="bg-gray-50 border border-gray-200 rounded p-3 text-xs overflow-x-auto"><code>${ex.code.replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]!))}</code></pre>`
          ).join('');
      }

      // 公式ドキュメントリンク
      const linksContainer = document.getElementById('feature-links') as HTMLElement;
      const officialLink = (f.links ?? []).find((l: any) => l.label?.includes('公式'));
      if (officialLink) {
        linksContainer.innerHTML = `<a href="${officialLink.url}" target="_blank" rel="noopener" class="block text-center bg-amber-50 border border-amber-200 text-amber-800 rounded-lg py-2 text-sm font-semibold hover:bg-amber-100 transition mb-2">${officialLink.label} ↗</a>`;
      }

      document.getElementById('today-loading')!.style.display = 'none';
      (document.getElementById('today-content') as HTMLElement).style.display = 'block';

      document.getElementById('btn-touch')!.addEventListener('click', () => updateProgress('touch', f.id));
      document.getElementById('btn-skip')!.addEventListener('click', () => updateProgress('skip', f.id));
    }

    async function loadProgress() {
      const res = await fetch('/api/progress', { headers: { 'X-Anon-Id': anonId } });
      const data = await res.json();
      const current = data.streak ?? 0;
      const longest = data.longestStreak ?? 0;

      (document.getElementById('streak-count') as HTMLElement).textContent = String(current);
      (document.getElementById('touched-count') as HTMLElement).textContent = String(data.touched?.length ?? 0);

      const longestLabel = document.getElementById('longest-streak-label') as HTMLElement;
      const cheer = document.getElementById('streak-cheer') as HTMLElement;

      if (longest > 0) {
        longestLabel.textContent = `（最長 ${longest}）`;
      }

      // 励ましメッセージ：状況に応じて切替
      let msg = '';
      if (current === 0 && longest === 0) {
        // 初回ユーザー
      } else if (current === 0 && longest > 0) {
        msg = `🌱 再スタート！過去最長 ${longest} 日を更新しよう`;
      } else if (current >= longest && current > 0) {
        msg = `🏆 自己ベスト更新中！`;
      } else if (longest - current <= 3) {
        msg = `🚀 あと ${longest - current} 日で最長記録 ${longest} 日を更新`;
      } else if (current >= 7) {
        msg = `🔥 ${current} 日連続！継続中`;
      }

      if (msg) {
        cheer.textContent = msg;
        cheer.classList.remove('hidden');
      }
    }

    async function updateProgress(action: 'touch' | 'skip', featureId: string) {
      await fetch('/api/progress', {
        method: 'POST',
        headers: { 'X-Anon-Id': anonId, 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, featureId }),
      });
      await loadProgress();
    }

    Promise.all([loadToday(), loadProgress()]);
  </script>
</Base>
