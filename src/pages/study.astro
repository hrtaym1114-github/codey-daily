---
import Base from '../layouts/Base.astro';
import featuresData from '../../data/features.json';

const data = featuresData as any;
const features = data.features;
const total = features.length;

const labels: Record<string, string> = {
  'slash-command': 'Slash Commands',
  'tool': 'Built-in Tools',
  'hook': 'Hooks',
  'agent': 'Agents',
  'skill': 'Skills',
  'mcp': 'MCP',
  'mode': 'Modes',
  'file': 'Files & Memory',
  'cli': 'CLI Flags',
  'setting': 'Settings',
};

const categories = [...new Set(features.map((f: any) => f.category))] as string[];

const title = `フラッシュカード学習 — Codey Daily`;
const description = `Claude Code の標準機能 ${total} をフラッシュカード形式で学習。表→裏でめくって覚えよう。`;
---

<Base title={title} description={description}>
  <Fragment slot="head">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </Fragment>

  <main class="container mx-auto px-4 py-8 max-w-2xl">
    <nav class="text-sm mb-4">
      <a href="/" class="text-blue-600 hover:underline">← トップ</a>
    </nav>

    <header class="mb-5">
      <h1 class="text-3xl font-bold mb-1">📇 フラッシュカード</h1>
      <p class="text-sm text-gray-600">カードをタップして裏返し。<span class="font-semibold">スペース</span>でめくる、<span class="font-semibold">←/→</span>で前後。</p>
    </header>

    <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-3 mb-4 flex flex-wrap items-center gap-2 text-sm">
      <label class="flex items-center gap-1">
        <span class="text-gray-500">カテゴリ</span>
        <select id="cat-filter" class="border border-gray-300 rounded px-2 py-1 text-sm bg-white">
          <option value="">すべて ({total})</option>
          {categories.map((c) => (
            <option value={c}>{labels[c] ?? c} ({features.filter((f: any) => f.category === c).length})</option>
          ))}
        </select>
      </label>
      <button id="btn-shuffle" class="ml-auto bg-gray-100 hover:bg-gray-200 rounded px-3 py-1 text-sm font-semibold transition">🔀 シャッフル</button>
      <span id="progress-text" class="text-xs text-gray-500 w-full sm:w-auto sm:ml-2">- / -</span>
    </section>

    <div class="perspective">
      <div id="card" class="card-flip relative w-full min-h-[320px] cursor-pointer select-none">
        <div id="card-front" class="card-face bg-white rounded-2xl shadow-md p-7 flex flex-col justify-center items-center text-center">
          <p class="text-xs uppercase tracking-wider text-gray-500 mb-2" id="front-cat">-</p>
          <h2 class="text-3xl sm:text-4xl font-bold mb-3 break-all" id="front-name">読み込み中…</h2>
          <p class="text-xs text-gray-400 mt-3">タップして答えを見る</p>
        </div>
        <div id="card-back" class="card-face card-back bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl shadow-md p-6 overflow-y-auto">
          <p class="text-xs uppercase tracking-wider text-gray-500 mb-1" id="back-cat">-</p>
          <h3 class="text-xl font-bold mb-2" id="back-name">-</h3>
          <p class="text-sm text-gray-700 mb-3" id="back-summary">-</p>
          <p class="text-sm text-gray-600 mb-3 whitespace-pre-line" id="back-desc">-</p>
          <div id="back-examples" class="mb-2"></div>
          <p class="text-xs text-gray-400 mt-3 text-center">タップして表へ戻る</p>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-3 gap-2 mt-5">
      <button id="btn-prev" class="bg-gray-100 hover:bg-gray-200 rounded-lg py-3 font-semibold text-sm transition active:scale-95">← 前</button>
      <button id="btn-flip" class="bg-blue-500 hover:bg-blue-600 text-white rounded-lg py-3 font-semibold text-sm transition active:scale-95">めくる</button>
      <button id="btn-next" class="bg-gray-100 hover:bg-gray-200 rounded-lg py-3 font-semibold text-sm transition active:scale-95">次 →</button>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      <a href="/quiz" class="text-blue-600 hover:underline">📝 4択クイズで力試し →</a>
    </p>
  </main>

  <style>
    .perspective { perspective: 1200px; }
    .card-flip { transform-style: preserve-3d; transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
    .card-flip.flipped { transform: rotateY(180deg); }
    .card-face { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; }
    .card-back { transform: rotateY(180deg); }
  </style>

  <script define:vars={{ FEATURES: features, LABELS: labels }}>
    const state = {
      list: [...FEATURES],
      idx: 0,
      flipped: false,
    };

    const $card = document.getElementById('card');
    const $progress = document.getElementById('progress-text');
    const $catFilter = document.getElementById('cat-filter');

    function escapeHtml(s) {
      return String(s).replace(/[<>&]/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;' }[c]));
    }

    function render() {
      if (state.list.length === 0) {
        document.getElementById('front-name').textContent = '該当カードなし';
        document.getElementById('front-cat').textContent = '';
        $progress.textContent = '0 / 0';
        return;
      }
      const f = state.list[state.idx];
      document.getElementById('front-name').textContent = f.name;
      document.getElementById('front-cat').textContent = LABELS[f.category] ?? f.category;
      document.getElementById('back-name').textContent = f.name;
      document.getElementById('back-cat').textContent = LABELS[f.category] ?? f.category;
      document.getElementById('back-summary').textContent = f.summary_ja;
      document.getElementById('back-desc').textContent = f.description_ja;

      const $ex = document.getElementById('back-examples');
      if (f.examples && f.examples.length) {
        $ex.innerHTML = '<p class="text-xs font-semibold text-gray-700 mb-1">💡 例</p>' +
          f.examples.map((e) =>
            `<pre class="bg-white border border-gray-200 rounded p-2 text-xs overflow-x-auto"><code>${escapeHtml(e.code)}</code></pre>`
          ).join('');
      } else {
        $ex.innerHTML = '';
      }

      $progress.textContent = `${state.idx + 1} / ${state.list.length}`;
    }

    function flip() {
      state.flipped = !state.flipped;
      $card.classList.toggle('flipped', state.flipped);
    }

    function show(unflip) {
      if (unflip && state.flipped) {
        state.flipped = false;
        $card.classList.remove('flipped');
        setTimeout(render, 250);
      } else {
        render();
      }
    }

    function next() {
      if (state.list.length === 0) return;
      state.idx = (state.idx + 1) % state.list.length;
      show(true);
    }
    function prev() {
      if (state.list.length === 0) return;
      state.idx = (state.idx - 1 + state.list.length) % state.list.length;
      show(true);
    }
    function shuffle() {
      for (let i = state.list.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [state.list[i], state.list[j]] = [state.list[j], state.list[i]];
      }
      state.idx = 0;
      show(true);
    }
    function applyFilter() {
      const cat = $catFilter.value;
      state.list = cat ? FEATURES.filter((f) => f.category === cat) : [...FEATURES];
      state.idx = 0;
      show(true);
    }

    $card.addEventListener('click', flip);
    document.getElementById('btn-flip').addEventListener('click', (e) => { e.stopPropagation(); flip(); });
    document.getElementById('btn-next').addEventListener('click', next);
    document.getElementById('btn-prev').addEventListener('click', prev);
    document.getElementById('btn-shuffle').addEventListener('click', shuffle);
    $catFilter.addEventListener('change', applyFilter);

    document.addEventListener('keydown', (e) => {
      if (e.target instanceof HTMLSelectElement || e.target instanceof HTMLInputElement) return;
      if (e.key === ' ') { e.preventDefault(); flip(); }
      else if (e.key === 'ArrowRight') next();
      else if (e.key === 'ArrowLeft') prev();
    });

    shuffle();
  </script>
</Base>
