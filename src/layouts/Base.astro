---
import '../styles/global.css';
import { CF_BEACON_TOKEN } from '../lib/site-config';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Claude Code を毎日5秒で発見するWebアプリ' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FF6B35" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <slot name="head" />

    {CF_BEACON_TOKEN && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${CF_BEACON_TOKEN}"}`}
      ></script>
    )}
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <div id="auth-bar" class="bg-white border-b border-gray-200 px-4 py-2 text-xs flex justify-between items-center">
      <a href="/" class="font-bold text-gray-700">Codey Daily</a>
      <div id="auth-area" class="flex items-center gap-2">
        <span class="text-gray-400">読み込み中...</span>
      </div>
    </div>

    <slot />

    <script is:inline>
      function getAnonId() {
        let id = localStorage.getItem('cd_anon_id');
        if (!id) { id = crypto.randomUUID(); localStorage.setItem('cd_anon_id', id); }
        return id;
      }

      async function renderAuthBar() {
        const area = document.getElementById('auth-area');
        if (!area) return;
        try {
          const res = await fetch('/api/me');
          const data = await res.json();
          if (data.user) {
            const initial = (data.user.name || data.user.email || '?').charAt(0).toUpperCase();
            area.innerHTML = `
              <a href="/me" class="flex items-center gap-1.5 hover:bg-gray-50 rounded px-2 py-1">
                ${data.user.picture
                  ? '<img src="' + data.user.picture + '" alt="" class="w-5 h-5 rounded-full">'
                  : '<span class="w-5 h-5 rounded-full bg-blue-500 text-white flex items-center justify-center text-xs">' + initial + '</span>'}
                <span class="text-gray-700 max-w-[120px] truncate">${data.user.name || data.user.email}</span>
              </a>
              <button id="btn-logout" class="text-gray-400 hover:text-gray-600 text-xs">ログアウト</button>
            `;
            const lo = document.getElementById('btn-logout');
            if (lo) lo.addEventListener('click', async () => {
              await fetch('/api/auth/logout', { method: 'POST' });
              location.reload();
            });
          } else {
            const anonId = getAnonId();
            area.innerHTML = `
              <a href="/api/auth/google/login?anon_id=${encodeURIComponent(anonId)}" class="flex items-center gap-1.5 bg-white border border-gray-300 hover:border-blue-400 hover:bg-blue-50 rounded px-3 py-1 text-gray-700">
                <svg width="14" height="14" viewBox="0 0 48 48"><path fill="#4285f4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34a853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#fbbc05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34C2.85 17.09 2 20.45 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#ea4335" d="M24 9.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 3.18 29.93 1 24 1 15.4 1 7.96 5.93 4.34 13.12l7.35 5.7C13.42 13.62 18.27 9.75 24 9.75z"/></svg>
                <span>ログイン</span>
              </a>
            `;
          }
        } catch (e) {
          area.innerHTML = '<span class="text-gray-400">-</span>';
        }
      }
      renderAuthBar();
    </script>
  </body>
</html>
