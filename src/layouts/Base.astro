---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Claude Code を毎日5秒で発見するWebアプリ' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <slot />
  </body>
</html>
